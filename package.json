{
  "name": "comic-hunter",
  "version": "1.0.0",
  "description": "Monorepo for Comic Hunter - Reddit poller with React dashboard",
  "private": true,
  "workspaces": [
    "dashboard"
  ],
  "scripts": {
    "dev": "npx tsx api-server.ts",
    "start": "npx tsx reddit-poller.ts",
    "server": "npx tsx api-server.ts",
    "dashboard": "npm run dev --workspace=comic-hunter-dashboard",
    "dashboard:build": "npm run build --workspace=comic-hunter-dashboard",
    "dev:all": "turbo run dev --parallel",
    "build": "turbo run build",
    "dev:manual": "concurrently \"npm run server\" \"npm run dashboard\"",
    "test:api": "npx tsx test-discord.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "packageManager": "npm@10.0.0",
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "node-fetch": "^3.3.2",
    "pg": "^8.20.0",
    "prisma": "^7.5.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "concurrently": "^9.1.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md}": [
      "prettier --write"
    ]
  }
}
