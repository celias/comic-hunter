{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "persistent": true,
      "cache": false
    },
    "build": {
      "outputs": ["dist/**", ".next/**"],
      "dependsOn": ["^build"]
    },
    "start": {
      "persistent": true,
      "cache": false
    },
    "server": {
      "persistent": true,
      "cache": false
    },
    "dashboard": {
      "persistent": true,
      "cache": false
    }
  }
}
